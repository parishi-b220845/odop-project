{
  "name": "odop-backend",
  "version": "1.0.0",
  "description": "ODOP Marketplace Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node migrations/run.js",
    "migrate:reset": "node migrations/reset.js",
    "seed": "node seeds/run.js",
    "seed:csv": "node seeds/000_import_csv.js",
    "seed:bulk": "node seeds/000_import_csv.js && node seeds/run.js && node seeds/002_bulk_data.js",
    "seed:all": "node seeds/000_import_csv.js && node seeds/run.js && node seeds/002_bulk_data.js",
    "test": "jest --coverage"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.3",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "pg": "^8.11.3",
    "razorpay": "^2.9.2",
    "sharp": "^0.33.2",
    "slugify": "^1.6.6",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.3"
  }
